# Firebase Configuration
VITE_FIREBASE_API_KEY=your_firebase_api_key_here
VITE_FIREBASE_AUTH_DOMAIN=your_firebase_auth_domain_here
VITE_FIREBASE_PROJECT_ID=your_firebase_project_id_here
VITE_FIREBASE_STORAGE_BUCKET=your_firebase_storage_bucket_here
VITE_FIREBASE_MESSAGING_SENDER_ID=your_firebase_messaging_sender_id_here
VITE_FIREBASE_APP_ID=your_firebase_app_id_here
FIREBASE_DATABASE_URL=your_firebase_realtime_database_url_here

# Firebase Admin SDK (for Node backend)
FIREBASE_SERVICE_ACCOUNT_PATH=firebase-admin-sdk.json

# Gemini API Configuration
VITE_GEMINI_API_KEY=your_gemini_api_key_here

# OpenAI API Configuration
OPENAI_API_KEY=your_openai_api_key_here

# HuggingFace API Configuration (for image generation)
VITE_HUGGINGFACE_API_KEY=your_huggingface_api_key_here

# Google Custom Search
VITE_GOOGLE_CUSTOM_SEARCH_ENGINE_ID=your_search_engine_id_here
VITE_GOOGLE_CUSTOM_SEARCH_API_KEY=your_google_search_api_key_here

# MongoDB Configuration
MONGODB_URI=your_mongodb_connection_string_here

# Email Configuration (Gmail)
EMAIL_USER=your_gmail_email_here
EMAIL_PASSWORD=your_gmail_app_password_here

# Twilio Configuration (Optional - for SMS)
TWILIO_ACCOUNT_SID=your_twilio_account_sid_here
TWILIO_AUTH_TOKEN=your_twilio_auth_token_here
TWILIO_PHONE_NUMBER=your_twilio_phone_number_here

# ESP32 Configuration
ESP32_IP=http://192.168.29.103
ESP32_PORT=80

# API URLs
VITE_FLASK_API_URL=https://your-render-app.onrender.com/python
VITE_API_BASE_URL=https://your-render-app.onrender.com

# Environment
VITE_APP_ENV=production
NODE_ENV=production
