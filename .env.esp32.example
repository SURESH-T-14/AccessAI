# ESP32 Configuration - Buzzer Only Setup
# Add these settings to your .env file

# ==========================================
# ESP32 Emergency Buzzer Device
# ==========================================

# IP Address of your ESP32 device
# Find this in the Serial Monitor output when ESP32 starts
ESP32_IP=http://192.168.1.42

# Port on which ESP32 is listening (usually 80 for HTTP)
ESP32_PORT=80

# Setup Instructions:
# After uploading the esp32_emergency_alert.ino sketch:
# 1. Open Serial Monitor at 115200 baud
# 2. Press RESET button on ESP32
# 3. Look for "IP Address: X.X.X.X"
# 4. Update ESP32_IP above with that address
# 5. Restart your backend server: npm run server
# 6. Click Emergency Alert button in app
#    - Buzzer sounds for 2 minutes
#    - SMS/Email sent to emergency contacts
#    - Buzzer auto-stops after 2 minutes

# Hardware Connections:
# ESP32 Pin 5 → Buzzer (+)
# ESP32 GND   → Buzzer (-)
# No LED needed!

# Multiple Devices (Optional):
# To support multiple devices, update server.js ESP32_DEVICES object
# ESP32_IP_MAIN=http://192.168.1.42
# ESP32_IP_BACKUP=http://192.168.1.43
